{
  "_comment": "Z-Image-Turbo Q4_K_M GGUF workflow optimised for 8 GB VRAM. Sampler dpmpp_sde + beta gives sharper detail and natural textures vs euler/simple (validated against MyAIForce 560-image study). Z-Image-Turbo is trained with guidance_scale=0.0, so negative prompts are IGNORED — we use ConditioningZeroOut. Default vertical 720x1280 keeps inference inside VRAM without offload.",
  "_placeholders": "{{prompt}} {{width}} {{height}} {{seed}}",
  "1": {
    "class_type": "UnetLoaderGGUF",
    "_meta": {"title": "Z-Image-Turbo Q4_K_M (GGUF)"},
    "inputs": {
      "unet_name": "z-image-turbo-Q4_K_M.gguf"
    }
  },
  "2": {
    "class_type": "CLIPLoader",
    "_meta": {"title": "Qwen3 4B (Z-Image text encoder, Lumina2 family)"},
    "inputs": {
      "clip_name": "qwen_3_4b_fp8_mixed.safetensors",
      "type": "lumina2"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "ae.safetensors"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive prompt — cinematic, no SDXL-isms"},
    "inputs": {
      "text": "{{prompt}}, cinematic anamorphic 2.39:1 framing, volumetric god rays, Kodak Portra 400 film grade, teal-and-orange tones, jade mountains and silk hanfu in xianxia mood, sharp focus on subject, natural skin texture, ink-wash atmosphere",
      "clip": ["2", 0]
    }
  },
  "5": {
    "class_type": "ConditioningZeroOut",
    "_meta": {"title": "Negative (Turbo ignores it; zero-out is canonical)"},
    "inputs": {
      "conditioning": ["4", 0]
    }
  },
  "6": {
    "class_type": "ModelSamplingAuraFlow",
    "_meta": {"title": "Z-Image is Lumina2 / Flow-matching family"},
    "inputs": {"model": ["1", 0], "shift": 3.0}
  },
  "7": {
    "class_type": "EmptyLatentImage",
    "inputs": {"width": "{{width}}", "height": "{{height}}", "batch_size": 1}
  },
  "8": {
    "class_type": "KSampler",
    "_meta": {"title": "Z-Image-Turbo (8 steps, cfg=1, dpmpp_sde/beta)"},
    "inputs": {
      "seed": "{{seed}}",
      "steps": 8,
      "cfg": 1.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "beta",
      "denoise": 1.0,
      "model": ["6", 0],
      "positive": ["4", 0],
      "negative": ["5", 0],
      "latent_image": ["7", 0]
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["8", 0], "vae": ["3", 0]}
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {"filename_prefix": "xianxia", "images": ["9", 0]}
  }
}
