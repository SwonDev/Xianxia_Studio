{
  "_comment": "ComfyUI workflow for Z-Image-Turbo. Loaded by routes/image.py when XIANXIA_USE_COMFYUI=1. Use ComfyUI-GGUF custom node when running on <8 GB VRAM (replace UNetLoaderGGUF -> CheckpointLoaderSimple).",
  "_placeholders": "{{prompt}} {{width}} {{height}} {{seed}}",
  "3": {
    "class_type": "KSampler",
    "_meta": { "title": "Z-Image-Turbo Sampler" },
    "inputs": {
      "seed": "{{seed}}",
      "steps": 9,
      "cfg": 0.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["10", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": "{{width}}", "height": "{{height}}", "batch_size": 1 }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive (xianxia)" },
    "inputs": { "text": "{{prompt}}, cinematic xianxia, jade mountains, swirling qi mist, golden hour, ultra detailed, epic composition, photorealistic, 8k", "clip": ["11", 0] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" },
    "inputs": { "text": "low quality, blurry, distorted, watermark, text overlay, modern", "clip": ["11", 0] }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["12", 0] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "xianxia", "images": ["8", 0] }
  },
  "10": {
    "class_type": "UNetLoaderGGUF",
    "_meta": { "title": "Z-Image-Turbo GGUF Q8" },
    "inputs": { "unet_name": "z-image-turbo-Q8_0.gguf" }
  },
  "11": {
    "class_type": "CLIPLoader",
    "_meta": { "title": "Z-Image text encoder" },
    "inputs": { "clip_name": "z-image-clip.safetensors", "type": "default" }
  },
  "12": {
    "class_type": "VAELoader",
    "inputs": { "vae_name": "z-image-vae.safetensors" }
  }
}
