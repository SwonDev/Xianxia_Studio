{
  "name": "@xianxia/sidecar-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs'),p=require('path');function cp(src,dst){fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src,{withFileTypes:true})){const s=p.join(src,f.name),d=p.join(dst,f.name);if(f.isDirectory())cp(s,d);else fs.copyFileSync(s,d);}console.log('copied',src,'->',dst);}cp(p.join('src','templates'),p.join('dist','templates'));cp(p.join('src','assets'),p.join('dist','assets'));\"",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "execa": "^9.5.2",
    "fastify": "^5.2.0",
    "hyperframes": "^0.4.45",
    "nanoid": "^5.0.9",
    "p-limit": "^6.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
